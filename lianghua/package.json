{
  "name": "lianghua-trade-sim",
  "version": "1.0.0",
  "description": "黑客帝国风格虚拟量化交易推演模拟器",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @lianghua/backend",
    "dev:frontend": "npm run dev -w @lianghua/frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build -w @lianghua/backend && npm run build -w @lianghua/frontend",
    "test": "npm run test -w @lianghua/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
